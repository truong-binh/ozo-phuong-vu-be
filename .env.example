# === Lark app credentials (tạo tại https://open.larksuite.com) ===
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URI — PHẢI khai báo y hệt trong app console (mục Security settings / Redirect URLs)
LARK_REDIRECT_URI=http://localhost:5173/auth/callback

# Quay lại client sau khi đăng nhập
CLIENT_URL=http://localhost:5173

# Scopes (phải bật tương ứng trong app console). Giữ mặc định là được.
LARK_SCOPES=wiki:wiki:readonly sheets:spreadsheet:readonly drive:drive:readonly offline_access

# (tuỳ chọn) link sheet mặc định
LARK_SHEET_URL=

# Ký cookie phiên — đổi thành chuỗi ngẫu nhiên bất kỳ
SESSION_SECRET=doi-thanh-chuoi-ngau-nhien

PORT=3000

# Nếu công ty dùng Feishu (bản Trung Quốc) thay vì Larksuite quốc tế thì đổi 2 dòng sau:
# LARK_OPEN_BASE=https://open.feishu.cn
# LARK_ACCOUNTS_BASE=https://accounts.feishu.cn
