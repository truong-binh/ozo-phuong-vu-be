# === Lark app credentials (tạo tại https://open.larksuite.com) ===
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect URI — PHẢI khai báo y hệt trong app console (mục Security settings / Redirect URLs)
LARK_REDIRECT_URI=http://localhost:5173/auth/callback

# Quay lại client sau khi đăng nhập
CLIENT_URL=http://localhost:5173

# Scopes (phải bật tương ứng trong app console). Giữ mặc định là được.
LARK_SCOPES=wiki:wiki:readonly sheets:spreadsheet:readonly drive:drive:readonly offline_access

# (tuỳ chọn) link sheet mặc định
LARK_SHEET_URL=

# === CHẾ ĐỘ NÚT VBA TRONG EXCEL (endpoint GET /api/values) — CÁCH B ===
# Bấm 1 nút trong file Excel -> tự kéo Lark -> ghi cột G.
# Cách B: KHÔNG cần add bot. Chỉ cần MỘT NGƯỜI đăng nhập Lark 1 lần trên web
# (tab chế độ ② -> "Đăng nhập bằng Lark"); server lưu refresh_token và nút Excel
# dùng token đó. Đăng nhập lại chỉ khi >~30 ngày không dùng.
#
# Khoá bảo vệ endpoint — đổi thành chuỗi ngẫu nhiên; VBA gửi kèm khoá này.
BUTTON_API_KEY=doi-thanh-chuoi-bi-mat

# Nơi lưu refresh_token. Trên Render PHẢI mount 1 persistent disk rồi trỏ vào đó,
# nếu không token sẽ mất mỗi lần deploy (phải đăng nhập lại).
#   Ví dụ Render: tạo Disk mount /data  ->  TOKEN_STORE_PATH=/data/lark-token.json
# Chạy local để trống là được (mặc định lưu server/.lark-token.json).
# TOKEN_STORE_PATH=/data/lark-token.json
# LARK_SHEET_URL ở trên là bắt buộc cho chế độ nút. sheetId để trống = sheet đầu tiên.
# LARK_SHEET_ID=
# Ánh xạ cột bên Lark (mặc định trùng README):
# LARK_HEADER_ROW=1
# LARK_SKU_COL=B
# LARK_ORDER_COL=I
# LARK_RECV_COL=J
# LARK_STATUS_COL=AP
# LARK_PROCESS_VALUE=On process
# LARK_LAST_COL=BZ
# LARK_MAX_ROWS=5000
# Ánh xạ bên Excel (VBA đọc từ response):
# EXCEL_KEY_COL=A
# EXCEL_TARGET_COL=G
# EXCEL_FIRST_ROW=3

# Ký cookie phiên — đổi thành chuỗi ngẫu nhiên bất kỳ
SESSION_SECRET=doi-thanh-chuoi-ngau-nhien

PORT=3000

# Nếu công ty dùng Feishu (bản Trung Quốc) thay vì Larksuite quốc tế thì đổi 2 dòng sau:
# LARK_OPEN_BASE=https://open.feishu.cn
# LARK_ACCOUNTS_BASE=https://accounts.feishu.cn
